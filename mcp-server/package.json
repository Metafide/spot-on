{
  "name": "metafide-spoton-mcp",
  "version": "1.2.0",
  "description": "MCP server for Metafide Spot-On prediction game",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "metafide-spoton-mcp": "dist/src/index.js",
    "metafide-spoton-setup": "dist/bin/setup.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup": "node dist/bin/setup.js",
    "prepare": "npm run build"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
